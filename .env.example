# --- Required ---
# Where to send Fable prompts. Your American friend's inbox.
FABLE_FRIEND_EMAIL=hank@example.com

# --- Gmail OAuth (Gmail API transport) ---
# Path to the OAuth client secret downloaded from Google Cloud Console
# (Desktop app credentials). Run `fable-meat-auth` once to mint the token.
FABLE_GMAIL_CREDENTIALS=credentials.json
FABLE_GMAIL_TOKEN=token.json

# --- Optional ---
# "me" sends as the authenticated Gmail account. Override to use an alias.
FABLE_SENDER_EMAIL=me
# Subject tag used to correlate the reply thread.
FABLE_SUBJECT_PREFIX=fable-meat
# How long to block waiting for your friend to reply, in BUSINESS DAYS (weekends
# skipped, computed against the wall clock). Humans need days. Default 7.
FABLE_REPLY_TIMEOUT_BUSINESS_DAYS=7
# Optional: override the business-day deadline with a raw seconds budget.
# Useful for tests/demos. Leave unset to use business days.
# FABLE_REPLY_TIMEOUT_SECONDS=3600
# How often to poll Gmail for the reply, in seconds (default 120).
FABLE_POLL_INTERVAL=120

# --- Real Anthropic passthrough ---
# Used for every non-Fable model. Standard Anthropic SDK env var.
ANTHROPIC_API_KEY=sk-ant-...
